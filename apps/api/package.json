    "@packsight/scanner-core": "workspace:*",
    "@packsight/shared": "workspace:*",
    "bullmq": "^5.34.1",
    "fastify": "^5.2.1",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
